generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  sku       String   @db.VarChar(20)
  filename  String   @db.VarChar(255)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([sku])
  @@map("product_images")
}

model ProductDescription {
  id          Int      @id @default(autoincrement())
  sku         String   @unique @db.VarChar(7)
  description String   @db.Text
  updatedAt   DateTime @updatedAt

  @@map("product_descriptions")
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(50)
  value String @db.VarChar(255)

  @@map("settings")
}

model HiddenCategory {
  id         Int    @id @default(autoincrement())
  categoryId String @unique @db.VarChar(4)

  @@map("hidden_categories")
}

model FeaturedBrand {
  id      Int    @id @default(autoincrement())
  brandId String @unique @db.VarChar(4)

  @@map("featured_brands")
}

model PriceSnapshot {
  id       Int      @id @default(autoincrement())
  sku      String   @db.VarChar(7)
  precio   Decimal  @db.Decimal(12, 2)
  precio2  Decimal  @db.Decimal(12, 2)
  precio4  Decimal  @db.Decimal(12, 2)
  takenAt  DateTime @default(now())

  @@unique([sku])
  @@map("price_snapshots")
}

model PriceChange {
  id          Int      @id @default(autoincrement())
  sku         String   @db.VarChar(7)
  name        String   @db.VarChar(255)
  field       String   @db.VarChar(20)
  oldPrice    Decimal  @db.Decimal(12, 2)
  newPrice    Decimal  @db.Decimal(12, 2)
  detectedAt  DateTime @default(now())

  @@index([detectedAt])
  @@index([sku])
  @@map("price_changes")
}

model Combo {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(100)
  description String?     @db.Text
  price       Decimal?    @db.Decimal(12, 2)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  items       ComboItem[]

  @@map("combos")
}

model ComboItem {
  id       Int    @id @default(autoincrement())
  comboId  Int
  sku      String @db.VarChar(7)
  quantity Int    @default(1)
  combo    Combo  @relation(fields: [comboId], references: [id], onDelete: Cascade)

  @@index([comboId])
  @@map("combo_items")
}

model ArchivedOrder {
  id          Int      @id @default(autoincrement())
  boleta      String   @db.VarChar(9)
  nroped      String   @db.VarChar(8)
  fechora     String   @db.VarChar(14)
  clienteCod  String   @db.VarChar(7)
  clienteName String   @db.VarChar(60)
  totalCant   Decimal  @db.Decimal(12, 3)
  total       Decimal  @db.Decimal(12, 2)
  notas       String?  @db.Text
  archivedAt  DateTime @default(now())

  items       ArchivedOrderItem[]

  @@index([clienteCod])
  @@index([fechora])
  @@map("archived_orders")
}

model ArchivedOrderItem {
  id          Int    @id @default(autoincrement())
  orderId     Int
  sku         String @db.VarChar(7)
  productName String @db.VarChar(60)
  cant        Decimal @db.Decimal(12, 3)
  precio      Decimal @db.Decimal(12, 2)
  impo        Decimal @db.Decimal(12, 2)
  listaPrecio Int

  order       ArchivedOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("archived_order_items")
}

model ClientDeliveryDay {
  id        Int    @id @default(autoincrement())
  clientId  String @db.VarChar(7)
  day       String @db.VarChar(20)

  @@unique([clientId, day])
  @@index([clientId])
  @@map("client_delivery_days")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(50)
  passwordHash String   @db.VarChar(255)
  role         String   @default("customer") @db.VarChar(20)
  createdAt    DateTime @default(now())

  @@map("users")
}
